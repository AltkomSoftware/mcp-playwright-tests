# Przykładowy plik konfiguracji środowiska
# Skopiuj ten plik do .env i dostosuj wartości

# URL bazowy aplikacji testowej
BASE_URL=https://backoffice-web-app.ais-demo.link/

# Dane użytkownika testowego (opcjonalnie)
TEST_USER_EMAIL=admin.auto
TEST_USER_PASSWORD=Qaddler50!!!

# Timeouty (w milisekundach)
DEFAULT_TIMEOUT=30000
ACTION_TIMEOUT=10000

# Tryb wykonania
HEADLESS=false
SLOW_MO=0

# Przeglądarki do testowania (chromium, firefox, webkit)
BROWSERS=chromium

# Poziom logowania (0 = brak, 1 = podstawowy, 2 = szczegółowy)
DEBUG_LEVEL=1


